{
  "name": "image-thumbnail-explorer",
  "displayName": "Image Thumbnail Explorer",
  "description": "\"An extension that help preview image thumbnail from the explorer tree\"",
  "icon": "images/icon.png",
  "publisher": "marvel-dev",
  "repository": "https://github.com/Blue-Marvel/image-thumbnail-explorer.git",
  "version": "0.0.5",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:imageThumbnailExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "imageThumbnailExplorer",
          "name": "Image Thumbnails",
          "icon": "$(file-media)",
          "contextualTitle": "Images"
        }
      ]
    },
    "commands": [
      {
        "command": "imageThumbnailExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "imageThumbnailExplorer.rename",
        "title": "Rename Image",
        "icon": "$(edit)"
      },
      {
        "command": "imageThumbnailExplorer.delete",
        "title": "Delete Image",
        "icon": "$(trash)"
      },
      {
        "command": "imageThumbnailExplorer.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "imageThumbnailExplorer.duplicate",
        "title": "Duplicate Image"
      },
      {
        "command": "imageThumbnailExplorer.add",
        "title": "Add Image",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "imageThumbnailExplorer.add",
          "when": "view == imageThumbnailExplorer",
          "group": "navigation@1"
        },
        {
          "command": "imageThumbnailExplorer.refresh",
          "when": "view == imageThumbnailExplorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "imageThumbnailExplorer.add",
          "when": "view == imageThumbnailExplorer && viewItem == folder",
          "group": "1_modification@1"
        },
        {
          "command": "imageThumbnailExplorer.rename",
          "when": "view == imageThumbnailExplorer && viewItem == image",
          "group": "1_modification@2"
        },
        {
          "command": "imageThumbnailExplorer.delete",
          "when": "view == imageThumbnailExplorer && viewItem == image",
          "group": "1_modification@3"
        },
        {
          "command": "imageThumbnailExplorer.duplicate",
          "when": "view == imageThumbnailExplorer && viewItem == image",
          "group": "2_copying@1"
        },
        {
          "command": "imageThumbnailExplorer.copyPath",
          "when": "view == imageThumbnailExplorer && viewItem == image",
          "group": "2_copying@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "imageThumbnailExplorer.rename",
        "key": "f2",
        "mac": "enter",
        "when": "view == imageThumbnailExplorer && viewItem == image && listFocus"
      },
      {
        "key": "enter",
        "mac": "enter",
        "command": "imageThumbnailExplorer.open",
        "when": "focusedView == imageThumbnailExplorer && listFocus"
      },
      {
        "key": "cmd+shift+c",
        "command": "imageThumbnailExplorer.copyRelativePath",
        "when": "focusedView == imageThumbnailExplorer && listFocus"
      },
      {
        "command": "imageThumbnailExplorer.delete",
        "key": "delete",
        "mac": "cmd+backspace",
        "when": "view == imageThumbnailExplorer && viewItem == image && listFocus"
      },
      {
        "command": "imageThumbnailExplorer.copyPath",
        "key": "shift+alt+c",
        "mac": "alt+cmd+c",
        "when": "view == imageThumbnailExplorer && viewItem == image && listFocus"
      },
      {
        "command": "imageThumbnailExplorer.duplicate",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "view == imageThumbnailExplorer && viewItem == image && listFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}